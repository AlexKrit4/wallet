# Public URL and TLS domain (DNS A/AAAA must point to VPS)
DOMAIN="wallet.example.com"
APP_URL="https://wallet.example.com"
ACME_EMAIL="ops@example.com"

# PostgreSQL / Redis — generate strong unique passwords
POSTGRES_DB="wallet"
POSTGRES_USER="wallet"
POSTGRES_PASSWORD="REPLACE_WITH_RANDOM_32_CHARS"
DATABASE_URL="postgresql://wallet:REPLACE_WITH_RANDOM_32_CHARS@postgres:5432/wallet?schema=public"
REDIS_PASSWORD="REPLACE_WITH_ANOTHER_RANDOM_32_CHARS"
REDIS_URL="redis://:REPLACE_WITH_ANOTHER_RANDOM_32_CHARS@redis:6379/0"

# Generate with: openssl rand -base64 48
AUTH_SECRET="REPLACE_WITH_AT_LEAST_32_RANDOM_CHARS"

# Generate offline with: npm run wallet:mnemonic
MASTER_MNEMONIC="REPLACE WITH A NEW 24 WORD MNEMONIC"

# Dedicated hot wallet; must hold USDT plus BNB for withdrawals and gas top-ups
HOT_WALLET_PRIVATE_KEY="0xREPLACE_WITH_PRIVATE_KEY"

# Use a paid/dedicated BSC mainnet HTTPS RPC for reliable getLogs
BSC_RPC_URL="https://YOUR_BSC_MAINNET_RPC"
USDT_CONTRACT_ADDRESS="0x55d398326f99059fF775485246999027B3197955"
DEPOSIT_POLL_MS="12000"
DEPOSIT_BLOCK_BATCH="1000"
DEPOSIT_CONFIRMATIONS="12"
# Optional deployment-time cursor; omit to start at current confirmed tip
# BSC_START_BLOCK=""

MIN_WITHDRAWAL="1"
MAX_WITHDRAWAL_PER_DAY="1000"
WITHDRAW_FEE="0.1"
WITHDRAW_POLL_MS="10000"
WITHDRAW_MAX_ATTEMPTS="5"
WITHDRAW_REPLACE_AFTER_MS="120000"

SWEEPER_POLL_MS="60000"
SWEEP_MIN_USDT="1"
SWEEP_GAS_TOPUP_BNB="0.0003"
SWEEP_TRANSFER_GAS_LIMIT="100000"

ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="REPLACE_WITH_STRONG_ADMIN_PASSWORD"
